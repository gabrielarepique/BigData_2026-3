# Importar SparkSession y crear una instancia
from pyspark.sql import SparkSession

spark = SparkSession.builder.appName("DataAnalysis").getOrCreate()
print("SparkSession creada.")
## Punto 1: Cargar los datos guardados en .parquet con PySpark
# Cargar los archivos parquet con PySpark
db1_spark = spark.read.parquet("file:///content/part-00000-b218a7bc-4e63-4796-b73d-e64fcbcabbb7-c000.snappy.parquet")
db2_spark = spark.read.parquet("file:///content/part-00001-b218a7bc-4e63-4796-b73d-e64fcbcabbb7-c000.snappy.parquet")

# Unir las dos bases de datos
db_total_spark = db1_spark.union(db2_spark)

# Mostrar el esquema y las primeras filas del DataFrame de PySpark
db_total_spark.printSchema()
db_total_spark.show(5)
## Punto 2: Análisis de datos con PySpark

Vamos a resolver las preguntas de análisis utilizando PySpark.
### a) ¿Cuántos hombres y cuántas mujeres hay en la base?
# Contar hombres y mujeres con PySpark
gender_counts_spark = db_total_spark.groupBy("Sexo").count()
gender_counts_spark.show()

# Opcional: Extraer los valores para una salida similar a la de Pandas
gender_counts_pd = gender_counts_spark.toPandas()
filtro_m_spark = gender_counts_pd[gender_counts_pd['Sexo'] == 'M']['count'].iloc[0] if 'M' in gender_counts_pd['Sexo'].values else 0
filtro_f_spark = gender_counts_pd[gender_counts_pd['Sexo'] == 'F']['count'].iloc[0] if 'F' in gender_counts_pd['Sexo'].values else 0

print(f"Total de hombres (PySpark): {filtro_m_spark}")
print(f"Total de mujeres (PySpark): {filtro_f_spark}")
db_total.info()
### b) ¿Cuál es la carrera con mayor cantidad de estudiantes?
# Encontrar la carrera con mayor cantidad de estudiantes con PySpark
career_counts_spark = db_total_spark.groupBy("Carrera").count()

# Ordenar en forma descendente y tomar la primera fila para encontrar la carrera con más estudiantes
most_students_career = career_counts_spark.orderBy('count', ascending=False).first()

carrera_mas_estudiantes_spark = most_students_career['Carrera']
n_estudiantes_spark = most_students_career['count']

print(f"Carrera con mayor cantidad de estudiantes (PySpark): '{carrera_mas_estudiantes_spark}' con {n_estudiantes_spark} estudiantes.")
### c) ¿Cuántos estudiantes tienen menos de 25 años?
# Contar estudiantes menores de 25 años con PySpark
from pyspark.sql.functions import col

estudiantes_menores_25_spark = db_total_spark.filter(col("Edad") < 25).count()

print(f"Cantidad de estudiantes menores de 25 años (PySpark): {estudiantes_menores_25_spark}")
### d) ¿Cuántos estudiantes tienen un promedio acumulado menor a 3?
# Contar estudiantes con promedio acumulado menor a 3 con PySpark
from pyspark.sql.functions import col

cant_estudiantes_promedio_spark = db_total_spark.filter(col("Promedio_Acumulado") < 3.0).count()

print(f"Cantidad de estudiantes con promedio acumulado menor a 3.0 (PySpark): {cant_estudiantes_promedio_spark}")
### e) ¿Cuál es la ciudad con mayor cantidad de estudiantes y cuál con la menor?
# Contar estudiantes por ciudad y encontrar la ciudad con mayor y menor cantidad con PySpark
from pyspark.sql.functions import col

city_counts_spark = db_total_spark.groupBy("Ciudad_Procedencia").count()

# Ciudad con mayor cantidad de estudiantes
ciudad_mas_estudiantes_spark_row = city_counts_spark.orderBy(col('count').desc()).first()
ciudad_mas_estudiantes_spark = ciudad_mas_estudiantes_spark_row['Ciudad_Procedencia']
cant_mas_estudiantes_spark = ciudad_mas_estudiantes_spark_row['count']

# Ciudad con menor cantidad de estudiantes
ciudad_menos_estudiantes_spark_row = city_counts_spark.orderBy(col('count').asc()).first()
ciudad_menos_estudiantes_spark = ciudad_menos_estudiantes_spark_row['Ciudad_Procedencia']
cant_menos_estudiantes_spark = ciudad_menos_estudiantes_spark_row['count']

print(f"Ciudad con mayor cantidad de estudiantes (PySpark): '{ciudad_mas_estudiantes_spark}' con {cant_mas_estudiantes_spark} estudiantes.")
print(f"Ciudad con menor cantidad de estudiantes (PySpark): '{ciudad_menos_estudiantes_spark}' con {cant_menos_estudiantes_spark} estudiantes.")
### f) ¿Cuántos estudiantes ya están graduados?
# Contar estudiantes graduados con PySpark
from pyspark.sql.functions import col

graduados_spark = db_total_spark.filter(col("Estado_Academico") == "Graduado").count()

print(f"Cantidad de graduados (PySpark): {graduados_spark}")
## Punto 3: Visualizaciones con PySpark
##Punto 3
###Gráfica de barras apiladas de cantidad de estudiantes por carrera.
# Contar estudiantes por carrera con PySpark
career_counts_spark_df = db_total_spark.groupBy("Carrera").count()

# Convertir a Pandas DataFrame para visualización
conteo_carreras_pd = career_counts_spark_df.toPandas()
conteo_carreras_pd.columns = ['Carrera', 'Cantidad_Estudiantes']

# Ordenar para la gráfica
conteo_carreras_pd = conteo_carreras_pd.sort_values(by='Cantidad_Estudiantes', ascending=False)

# Generar la gráfica de barras
import matplotlib.pyplot as plt
import seaborn as sns

plt.figure(figsize=(10, 3))
sns.barplot(x="Carrera", y="Cantidad_Estudiantes", data=conteo_carreras_pd, palette="viridis")
plt.title("Cantidad de estudiantes por carrera (PySpark)")
plt.xlabel("Carrera")
plt.ylabel("Cantidad de estudiantes")
plt.grid()
plt.show()
### Gráfica de torta mostrando la distribución de estudiantes por Edad.
# Contar la distribución de edades con PySpark
age_counts_spark_df = db_total_spark.groupBy("Edad").count()

# Convertir a Pandas DataFrame para visualización
conteo_edades_pd = age_counts_spark_df.toPandas()
conteo_edades_pd.columns = ['Edad', 'Cantidad_Estudiantes']

# Generar la gráfica de torta
import matplotlib.pyplot as plt
import seaborn as sns

plt.figure(figsize=(8, 8))
plt.pie(conteo_edades_pd['Cantidad_Estudiantes'], labels=conteo_edades_pd['Edad'], autopct='%1.1f%%', startangle=45, colors=sns.color_palette("viridis"))
plt.title("Distribución de estudiantes por edad (PySpark)")
plt.show()
### Histograma de carreras que hay en la ciudad de Medellín.
# Filtrar estudiantes de Medellín y contar carreras con PySpark
carreras_medellin_spark_df = db_total_spark.filter(col("Ciudad_Procedencia") == "Medellín")\
                                              .groupBy("Carrera").count()

# Convertir a Pandas DataFrame para visualización
carreras_medellin_pd = carreras_medellin_spark_df.toPandas()
carreras_medellin_pd.columns = ['Carrera', 'Número_Estudiantes']

# Generar el histograma
import matplotlib.pyplot as plt
import seaborn as sns

plt.figure(figsize=(10, 6))
sns.barplot(x="Carrera", y="Número_Estudiantes", data=carreras_medellin_pd, palette='viridis')
plt.title('Distribución de Carreras en Medellín (PySpark)')
plt.xlabel('Carrera')
plt.ylabel('Número de Estudiantes')
plt.grid()
plt.show()
